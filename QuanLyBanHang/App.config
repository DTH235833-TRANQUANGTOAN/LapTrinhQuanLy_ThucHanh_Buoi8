<configuration>
	<connectionStrings>
		<add name="QLBHConnection"
			 connectionString="Data Source=.;Initial Catalog=QLBH;Integrated Security=True;Encrypt=True;TrustServerCertificate=True"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>
</configuration>